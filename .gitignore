# See https://www.dartlang.org/guides/libraries/private-files

# Files and directories created by pub
.dart_tool/
.packages
build/
# If you're building an application, you may want to check-in your pubspec.lock
pubspec.lock

# Directory created by dartdoc
# If you don't generate documentation locally you can remove this line.
doc/api/

# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
# Produced by the --dump-info flag.
*.info.json
# When generated by dart2js. Don't specify *.js if your
# project includes source files written in JavaScript.
*.js
*.js_
*.js.deps
*.js.map
*.log
.flutter-plugins
.flutter-plugins-dependencies

# macOS Finder metadata
.DS_Store

# Flutter / Dart local lockfile
pubspec.lock

# Local helper scripts
scripts/

# Keep only the local OHOS PDF viewer plugin source.
packages/*
!packages/flutter_pdfview_ohos/
!packages/flutter_pdfview_ohos/**

# Ignore generated artifacts inside the local plugin.
packages/flutter_pdfview_ohos/.dart_tool/
packages/flutter_pdfview_ohos/build/
packages/flutter_pdfview_ohos/ohos/build/
packages/flutter_pdfview_ohos/ohos/oh_modules/
packages/flutter_pdfview_ohos/example/.dart_tool/
packages/flutter_pdfview_ohos/example/build/
packages/flutter_pdfview_ohos/example/ohos/build/
packages/flutter_pdfview_ohos/example/ohos/oh_modules/
packages/flutter_pdfview_ohos/example/.flutter-plugins
packages/flutter_pdfview_ohos/example/.flutter-plugins-dependencies
packages/flutter_pdfview_ohos/example/pubspec.lock
packages/flutter_pdfview_ohos/pubspec.lock

# Old experimental PDF plugin, no longer used.
packages/pdf_render_ohos/

# DevEco / HarmonyOS local build caches and machine-specific files.
ohos/.hvigor/
ohos/.idea/
ohos/local.properties
ohos/oh-package-lock.json5
ohos/entry/oh-package-lock.json5
ohos/entry/libs/
ohos/entry/src/main/resources/rawfile/
packages/flutter_pdfview_ohos/.DS_Store
