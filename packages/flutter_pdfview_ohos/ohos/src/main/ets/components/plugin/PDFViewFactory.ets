import { PlatformViewFactory, BinaryMessenger, PlatformView } from '@ohos/flutter_ohos';
import MessageCodec from '@ohos/flutter_ohos/src/main/ets/plugin/common/MessageCodec';
import { FlutterPDFView } from './FlutterPDFView';
import common from '@ohos.app.ability.common';

export class PDFViewFactory extends PlatformViewFactory {
  message: BinaryMessenger;

  constructor(message: BinaryMessenger, createArgsCodes: MessageCodec<Object>) {
    super(createArgsCodes);
    this.message = message;
  }

  public create(context: common.UIAbilityContext, viewId: number, args: Object): PlatformView {
    return new FlutterPDFView(context, viewId, args, this.message);
  }
}